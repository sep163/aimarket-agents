# Telegram bot tokens (get from @BotFather). Agent 4 and Agent 5 can share one bot
# or use two separate bots - both work, just point both vars at the token(s) you want.
AGENT4_BOT_TOKEN=
AGENT5_BOT_TOKEN=

# LLM provider. Set LLM_PROVIDER=openai for any OpenAI-compatible endpoint
# (OpenAI, DeepSeek, OpenRouter, Groq, local vLLM, etc), or LLM_PROVIDER=anthropic
# for the native Anthropic Messages API.
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Google Sheets: leads + the "Links" admin tab used by Agent 4.
# GOOGLE_SERVICE_ACCOUNT_FILE points at a service-account JSON key with access
# to the spreadsheet (share the sheet with the service account's email).
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_SHEET_ID=

# Postgres used by Agent 5 (schema in agent5_marketing_analytics/schema.sql).
DATABASE_URL=postgresql://user:pass@localhost:5432/aimarket

# Ad platform credentials used by Agent 5's daily sync.
YANDEX_DIRECT_TOKEN=
VK_ADS_TOKEN=

# Telegram chat id that receives the weekly report (get it from @get_id_bot).
REPORT_CHAT_ID=

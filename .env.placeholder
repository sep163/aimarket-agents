# Заглушки для первого деплоя - структурно валидные, но нерабочие значения.
# deploy.sh копирует этот файл в .env, только если .env ещё не существует
# (то есть повторный запуск deploy.sh не затрёт уже вставленные реальные секреты).
#
# Что будет работать сразу: aimarket-agent5-scheduler (планировщик) стартует
# и остаётся живым - ему нечего слать наружу до первого запуска задачи.
# Что будет ждать реальный токен: aimarket-agent4-bot и aimarket-agent5-qa-bot
# не смогут авторизоваться в Telegram с этим токеном - это ожидаемо, они не
# крашатся, а раз в 30 секунд тихо пишут в лог и пробуют снова.

AGENT4_BOT_TOKEN=000000000:PLACEHOLDER-TOKEN-REPLACE-ME
AGENT5_BOT_TOKEN=000000000:PLACEHOLDER-TOKEN-REPLACE-ME

LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-placeholder-replace-me
LLM_MODEL=gpt-4o-mini

GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_SHEET_ID=placeholder-sheet-id-replace-me

DATABASE_URL=postgresql://aimarket:placeholder@localhost:5432/aimarket

YANDEX_DIRECT_TOKEN=placeholder-replace-me
VK_ADS_TOKEN=placeholder-replace-me

REPORT_CHAT_ID=000000000
